{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/tauri.conf.json",
  "productName": "Soufflé",
  "mainBinaryName": "souffle",
  "version": "0.1.0",
  "identifier": "com.souffle.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && ./scripts/build-mcp-sidecar.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Soufflé",
        "width": 860,
        "height": 780,
        "minWidth": 680,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "windowEffects": {
          "effects": [
            "underWindowBackground"
          ],
          "state": "active"
        }
      },
      {
        "label": "pill",
        "title": "",
        "width": 280,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false,
        "acceptFirstMouse": true,
        "visibleOnAllWorkspaces": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* https://huggingface.co https://*.hf.co; img-src 'self' data:; font-src 'self'"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/souffle-mcp"
    ],
    "resources": {
      "resources/silero_vad_v4.onnx": "resources/silero_vad_v4.onnx"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "13.0",
      "hardenedRuntime": true,
      "frameworks": [
        "resources/libonnxruntime.dylib"
      ]
    }
  },
  "plugins": {}
}
